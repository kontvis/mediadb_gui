# Copy to .env and fill in your values. Never commit .env.
# See README.md for setup; this file is the authoritative list of variables.

# --- Required ---
# PostgreSQL connection string.
# Linux (DB on same machine): use localhost:5432
# Windows via SSH tunnel: use localhost and SSH_TUNNEL_LOCAL_PORT below (often 15432)
DATABASE_URL=postgresql://mediadb_app:YOUR_PASSWORD@localhost:15432/media_catalog

SECRET_KEY=generate-a-long-random-string
FLASK_ENV=development

# --- Optional API keys ---
GOOGLE_VISION_API_KEY=
TMDB_API_KEY=

# --- SSH tunnel (Windows remote dev only; omit on Linux) ---
SSH_TUNNEL_HOST=192.168.1.50
SSH_TUNNEL_USER=your_linux_username
# Use 15432 if local port 5432 is already taken (common on Windows)
SSH_TUNNEL_LOCAL_PORT=15432
# SSH_TUNNEL_REMOTE_HOST=127.0.0.1
# SSH_TUNNEL_REMOTE_PORT=5432
